# Copy to .env.local for local development

NEXT_PUBLIC_API_URL="http://localhost:4000"
# Server-side fetch (SSR admin auth); usually same host as desktop, port as API
API_INTERNAL_URL="http://127.0.0.1:4000"
# Browser rewrites /v1 → API (see next.config.mjs); override if API runs elsewhere
API_PROXY_TARGET="http://127.0.0.1:4000"
# Optional — Phase 12 analytics / payments (omit in dev if unused)
NEXT_PUBLIC_META_PIXEL_ID=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
