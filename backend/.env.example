# Copy to .env and fill in values (never commit .env).
# Run `openssl rand -hex 48` to generate JWT secrets.

NODE_ENV=development
PORT=4000

# ---- Database ----
# Seed: npm run db:seed (optional: SEED_ADMIN_EMAIL, SEED_ADMIN_PASSWORD ≥8 chars + letter + digit)
# SEED_ADMIN_EMAIL=admin@diteup.local
# SEED_ADMIN_PASSWORD=
DATABASE_URL="postgresql://diteup:diteup_local_dev_only@localhost:5432/diteup?schema=public"

# ---- CORS (comma-separated origins) ----
CORS_ORIGIN="http://localhost:3000"

# ---- JWT (required) — ≥ 32 chars each ----
JWT_ACCESS_SECRET="change-me-to-a-long-random-string-min-32-chars"
JWT_REFRESH_SECRET="change-me-to-a-different-long-random-string-min-32"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- Razorpay (wired in Phase 6/9) ----
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# ---- Email — SMTP (preferred when SMTP_HOST set; nodemailer) ----
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# For port 465 use implicit TLS: SMTP_SECURE=true (or omit; defaulted when port is 465)
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# Dev only — self-signed MITM risk if false:
# SMTP_TLS_REJECT_UNAUTHORIZED=true

# ---- Email — Resend (used when SMTP_HOST is unset) ----
# RESEND_API_KEY=
EMAIL_FROM="DiteUp <no-reply@diteup.com>"

# ---- Object storage — Cloudflare R2 / S3 (wired in Phase 7/9) ----
# R2_ENDPOINT=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

# ---- Monitoring ----
# SENTRY_DSN=

# ---- Meta Conversions API (optional, PRD §9.5) ----
# META_PIXEL_ID=
# META_CAPI_ACCESS_TOKEN=

# ---- Admin encrypted settings (optional) ----
# SETTINGS_ENCRYPTION_KEY=

# ---- Public URLs (emails, List-Unsubscribe) ----
# PUBLIC_SITE_URL=https://diteup.com

# ---- GST invoice header overrides (optional) ----
# INVOICE_SELLER_NAME="NVHO Tech Pvt. Ltd."
# INVOICE_SELLER_GSTIN=08AAJCN8501H1ZC
# INVOICE_SELLER_STATE=Rajasthan

# ---- Rate limiting (optional; PRD §13.2 distributed limiter) ----
# REDIS_URL=redis://localhost:6379

# ---- Health probe (production) ----
# Require header X-Health-Secret on GET /health/db when NODE_ENV=production
# HEALTHCHECK_SECRET=

# ---- Resend inbound webhooks (Svix signing secret from Resend dashboard) ----
# RESEND_WEBHOOK_SECRET=

# ---- Marketing send throttle (broadcasts per minute to respect Resend limits) ----
# BROADCAST_EMAILS_PER_MINUTE=100

# ---- Background jobs / ops (Phase 10) ----
# ENABLE_BACKGROUND_JOBS=true
# STALE_ORDER_JOB_INTERVAL_MS=900000
# JOB_EMAIL_QUEUE_POLL_MS=15000
# ADMIN_ALERT_EMAILS=ops@example.com
# BACKUP_VERIFY_URL=

# ---- Misc ----
ENABLE_DEBUG_LOGS=false
