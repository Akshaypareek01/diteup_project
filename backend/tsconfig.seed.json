{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node16",
    "noEmit": true,
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": ["prisma/seed.ts", "src/utils/password.ts"]
}
