// DiteUp Prisma Schema — derived from PRD v1.0 §5
// Single source of truth for the database.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// ENUMS
// =====================================================

enum Role {
  CUSTOMER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum OTPPurpose {
  EMAIL_VERIFY
  PASSWORD_RESET
  LOGIN_2FA
  EMAIL_CHANGE
}

enum ProductVisibility {
  DRAFT
  PUBLISHED
  HIDDEN
  COMING_SOON
  OUT_OF_STOCK
  UNDER_MAINTENANCE
  ARCHIVED
}

enum ProductBadge {
  NEW
  BESTSELLER
  LIMITED
  SALE
  BACK_IN_STOCK
}

enum MediaType {
  IMAGE
  VIDEO
}

enum StockReason {
  MANUAL_ADD
  MANUAL_DEDUCT
  ORDER_RESERVE
  ORDER_CONFIRM
  ORDER_CANCEL
  ORDER_REFUND
  IMPORT
  INITIAL
}

enum OrderStatus {
  PLACED
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY
  COD
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum CouponType {
  FLAT
  PERCENT
  FREE_SHIPPING
}

enum EmailStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

// =====================================================
// USERS / AUTH
// =====================================================

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String?
  phone           String?
  name            String?
  gender          Gender?
  dateOfBirth     DateTime?
  profileImageUrl String?
  role            Role      @default(CUSTOMER)

  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  phoneVerified   Boolean   @default(false)
  phoneVerifiedAt DateTime?

  isActive            Boolean   @default(true)
  deactivationReason  String?
  lockedUntil         DateTime?
  failedLoginAttempts Int       @default(0)
  tokenVersion        Int       @default(0)

  restrictions Json?
  tags         String[] @default([])
  adminNotes   String?

  marketingOptIn   Boolean   @default(false)
  marketingOptInAt DateTime?

  lastLoginAt  DateTime?
  lastLoginIp  String?
  signupSource String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  addresses           Address[]
  orders              Order[]
  reviews             Review[]
  passwordResetTokens PasswordResetToken[]
  otps                AuthOTP[]
  reviewHelpfulVotes  ReviewHelpful[]

  @@index([isActive])
  @@index([emailVerified])
  @@index([role])
}

model AuthOTP {
  id           String     @id @default(cuid())
  userId       String?
  user         User?      @relation(fields: [userId], references: [id])
  email        String
  codeHash     String
  purpose      OTPPurpose
  expiresAt    DateTime
  attemptCount Int        @default(0)
  usedAt       DateTime?
  ip           String?
  createdAt    DateTime   @default(now())

  @@index([email, purpose])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  label     String?
  name      String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  country   String   @default("IN")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// =====================================================
// PRODUCTS
// =====================================================

model Product {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String
  shortDesc   String?
  isFeatured  Boolean @default(true)

  visibility     ProductVisibility @default(DRAFT)
  visibilityNote String?
  availableFrom  DateTime?
  availableUntil DateTime?

  isRefundable     Boolean @default(true)
  refundWindowDays Int?    @default(7)
  refundPolicyText String?
  isReturnable     Boolean @default(true)
  isExchangeable   Boolean @default(true)

  codEnabled           Boolean  @default(true)
  onlinePaymentEnabled Boolean  @default(true)
  freeShipping         Boolean  @default(false)
  shippingOverride     Decimal? @db.Decimal(10, 2)
  codChargeOverride    Decimal? @db.Decimal(10, 2)
  restrictedPincodes   Json?

  minQtyPerOrder   Int       @default(1)
  maxQtyPerOrder   Int       @default(10)
  allowBackorder   Boolean   @default(false)
  preorderEnabled  Boolean   @default(false)
  preorderShipDate DateTime?

  showStockCount   Boolean       @default(false)
  reviewsEnabled   Boolean       @default(true)
  displayBadge     ProductBadge?
  ctaLabelOverride String?

  requiresAgeVerification Boolean @default(false)
  hsnCode                 String?
  gstRate                 Decimal @default(0) @db.Decimal(5, 2)

  seo       Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  media    ProductMedia[]
  variants ProductVariant[]
  faqs     ProductFAQ[]
  reviews  Review[]

  @@index([visibility, isFeatured])
}

model ProductMedia {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      MediaType
  url       String
  altText   String?
  order     Int       @default(0)
  createdAt DateTime  @default(now())

  @@index([productId, order])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku       String   @unique
  name      String
  priceMrp  Decimal  @db.Decimal(10, 2)
  priceSale Decimal  @db.Decimal(10, 2)
  weightGm  Int?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory     Inventory?
  orderItems    OrderItem[]
  notifications StockNotification[]

  @@index([productId])
}

model ProductFAQ {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  question  String
  answer    String
  order     Int     @default(0)

  @@index([productId, order])
}

// =====================================================
// INVENTORY
// =====================================================

model Inventory {
  id                String   @id @default(cuid())
  variantId         String   @unique
  variant           ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  stockOnHand       Int      @default(0)
  stockReserved     Int      @default(0)
  lowStockThreshold Int      @default(10)
  updatedAt         DateTime @updatedAt

  history StockLedger[]
}

model StockLedger {
  id          String      @id @default(cuid())
  inventoryId String
  inventory   Inventory   @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  delta       Int
  reason      StockReason
  note        String?
  refOrderId  String?
  actorUserId String?
  createdAt   DateTime    @default(now())

  @@index([inventoryId, createdAt])
}

model StockNotification {
  id         String         @id @default(cuid())
  variantId  String
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  email      String
  phone      String?
  userId     String?
  notifiedAt DateTime?
  createdAt  DateTime       @default(now())

  @@unique([variantId, email])
  @@index([variantId, notifiedAt])
}

// =====================================================
// ORDERS
// =====================================================

model Order {
  id          String  @id @default(cuid())
  orderNumber String  @unique
  /** Optional client idempotency key (same key + actor ⇒ same order). */
  idempotencyKey String? @unique
  userId      String?
  user        User?   @relation(fields: [userId], references: [id])
  guestEmail  String?
  guestPhone  String?

  status        OrderStatus   @default(PLACED)
  paymentMethod PaymentMethod

  subtotal       Decimal @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  shippingAmount Decimal @default(0) @db.Decimal(10, 2)
  codCharge      Decimal @default(0) @db.Decimal(10, 2)
  taxAmount      Decimal @default(0) @db.Decimal(10, 2)
  total          Decimal @db.Decimal(10, 2)
  currency       String  @default("INR")

  couponCode String?

  shippingAddress      Json
  billingAddress       Json?
  refundPolicySnapshot Json?
  notes                String?
  cancelReason         String?

  awbNumber       String?
  shippingCarrier String?

  metaPixelEventId String?

  /** GST invoice no. — format `DU/YY-YY/NNNN` per PRD §9.4 (India FY, Asia-Kolkata). */
  invoiceNumber String? @unique
  invoicePdfUrl String?

  placedAt    DateTime  @default(now())
  confirmedAt DateTime?
  shippedAt   DateTime?
  deliveredAt DateTime?
  cancelledAt DateTime?
  updatedAt   DateTime  @updatedAt

  items      OrderItem[]
  payments   Payment[]
  events     OrderEvent[]
  redemption CouponRedemption?
  reviews    Review[]

  @@index([userId])
  @@index([status])
  @@index([placedAt])
  @@index([orderNumber])
}

model OrderItem {
  id          String         @id @default(cuid())
  orderId     String
  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id])
  productName String
  variantName String
  sku         String
  unitPrice   Decimal        @db.Decimal(10, 2)
  quantity    Int
  lineTotal   Decimal        @db.Decimal(10, 2)

  @@index([orderId])
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type      String
  payload   Json
  actorId   String?
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

/// Monotonic order suffix per calendar year (Asia/Kolkata) — format `DU-YYYY-NNNNN`.
model OrderSequence {
  year   Int @id
  lastNo Int @default(0)
}

/// Monotonic GST invoice suffix per India fiscal year label `YY-YY` — format `DU/YY-YY/NNNN`.
model InvoiceSequence {
  fiscalYearLabel String @id
  lastNo            Int @default(0)
}

// =====================================================
// PAYMENTS
// =====================================================

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method            PaymentMethod
  status            PaymentStatus
  amount            Decimal       @db.Decimal(10, 2)
  razorpayOrderId   String?       @unique
  razorpayPaymentId String?       @unique
  razorpaySignature String?
  failureReason     String?
  refundedAmount    Decimal       @default(0) @db.Decimal(10, 2)
  rawPayload        Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([orderId])
  @@index([status])
}

// =====================================================
// COUPONS
// =====================================================

model Coupon {
  id             String     @id @default(cuid())
  code           String     @unique
  description    String?
  type           CouponType
  value          Decimal    @db.Decimal(10, 2)
  minOrder       Decimal?   @db.Decimal(10, 2)
  maxDiscount    Decimal?   @db.Decimal(10, 2)
  usageLimit     Int?
  usedCount      Int        @default(0)
  perUserLimit   Int?       @default(1)
  firstOrderOnly Boolean    @default(false)
  appliesToCOD   Boolean    @default(true)
  startsAt       DateTime?
  endsAt         DateTime?
  isActive       Boolean    @default(true)
  source         String?
  createdBy      String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  redemptions CouponRedemption[]

  @@index([code])
  @@index([isActive, startsAt, endsAt])
}

model CouponRedemption {
  id             String    @id @default(cuid())
  couponId       String
  coupon         Coupon    @relation(fields: [couponId], references: [id])
  orderId        String    @unique
  order          Order     @relation(fields: [orderId], references: [id])
  userId         String?
  guestEmail     String?
  guestPhone     String?
  discountAmount Decimal   @db.Decimal(10, 2)
  cartSubtotal   Decimal   @db.Decimal(10, 2)
  redeemedAt     DateTime  @default(now())
  isReversed     Boolean   @default(false)
  reversedAt     DateTime?
  reversalReason String?

  @@index([couponId, userId])
  @@index([couponId, guestEmail])
  @@index([couponId, redeemedAt])
}

// =====================================================
// REVIEWS
// =====================================================

model Review {
  id           String    @id @default(cuid())
  productId    String
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?     @relation(fields: [userId], references: [id])
  orderId      String?
  order        Order?    @relation(fields: [orderId], references: [id])
  authorName   String
  rating       Int
  title        String?
  body         String
  images       Json?
  /** Denormalized for filtering (PRD §6.7.5 with-images). */
  hasImages    Boolean   @default(false)
  isApproved   Boolean   @default(false)
  isVerified   Boolean   @default(false)
  isFeatured   Boolean   @default(false)
  isFlagged    Boolean   @default(false)
  flagReason   String?
  adminReply   String?
  adminReplyAt DateTime?
  helpfulCount Int       @default(0)
  editedAt     DateTime?
  /** Author soft-delete — hidden from public; row retained for moderation/audit. */
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  helpfulVotes ReviewHelpful[]

  @@unique([userId, productId, orderId])
  @@index([productId, isApproved, rating])
  @@index([productId, deletedAt, isApproved])
}

model ReviewHelpful {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
}

// =====================================================
// EMAIL
// =====================================================

model BroadcastEmail {
  id          String      @id @default(cuid())
  subject     String
  bodyHtml    String
  segment     Json
  sentAt      DateTime?
  scheduledAt DateTime?
  sentCount   Int         @default(0)
  failedCount Int         @default(0)
  status      EmailStatus @default(DRAFT)
  createdBy   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model EmailLog {
  id                String   @id @default(cuid())
  to                String
  template          String
  refType           String?
  refId             String?
  status            String
  provider          String   @default("resend")
  providerMessageId String?
  error             String?
  sentAt            DateTime @default(now())

  @@index([to])
  @@index([status])
  @@index([refType, refId])
}

model EmailSuppression {
  email     String   @id
  reason    String
  createdAt DateTime @default(now())
}

// =====================================================
// SETTINGS / AUDIT
// =====================================================

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

enum BackgroundJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  DEAD
}

model BackgroundJob {
  id          String              @id @default(cuid())
  /** e.g. `email.send` */
  type        String
  payload     Json
  status      BackgroundJobStatus @default(PENDING)
  runAt       DateTime            @default(now())
  attempts    Int                 @default(0)
  maxAttempts Int                 @default(8)
  lastError   String?
  lockedAt    DateTime?
  completedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([status, runAt])
  @@index([type])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  diff      Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
}
